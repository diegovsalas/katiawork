# .env.example — copia este archivo a .env y pon tus valores reales.
# El .env real NO se sube al repo (está en .gitignore).
#
# En servidores como Render, Railway, Fly.io, Heroku, etc., configura
# estas variables directamente en el panel del proveedor (no subas .env).

# ---------------------------------------------------------------------
# Sesiones — llave para firmar cookies. Genera una con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ---------------------------------------------------------------------
SESSION_SECRET_KEY=cambia-esto-por-una-cadena-larga-aleatoria

# ---------------------------------------------------------------------
# Banregio — datos visibles al cliente para transferencia directa
# ---------------------------------------------------------------------
BANREGIO_TITULAR=Outlet Momatt México
BANREGIO_CLABE=000000000000000000
BANREGIO_CUENTA=0000000000
BANREGIO_WHATSAPP=+52 81 3568 7469
BANREGIO_CORREO=ventas@momatt.shop

# ---------------------------------------------------------------------
# Openpay — SPEI automático (sk_... son tus llaves del dashboard)
# OPENPAY_PRODUCCION=False usa sandbox; True cobra real.
# ---------------------------------------------------------------------
OPENPAY_MERCHANT_ID=
OPENPAY_PRIVATE_KEY=
OPENPAY_PRODUCCION=False

# ---------------------------------------------------------------------
# Stripe — scaffolded. Para activar: pon las 3 keys y termina las
# funciones marcadas TODO en pagos_stripe.py + IMPLEMENTACION_TERMINADA=True
# Webhook: configura https://momatt.shop/webhook/stripe en Stripe Dashboard.
# ---------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------
# Mercado Pago — scaffolded. Para activar: pon las keys, termina las
# funciones marcadas TODO en pagos_mercadopago.py + IMPLEMENTACION_TERMINADA=True
# Webhook: configura https://momatt.shop/webhook/mercadopago en MP Developers.
# MP_MSI_HABILITADO=True activa Meses Sin Intereses.
# ---------------------------------------------------------------------
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_MSI_HABILITADO=False

# ---------------------------------------------------------------------
# Postgres — Render la inyecta automáticamente. Para dev local pon:
#   DATABASE_URL=postgresql://usuario:pass@localhost:5432/momatt
# Si la dejas vacía, auth y persistencia de pedidos quedan deshabilitados
# (catálogo y guest checkout siguen funcionando).
# ---------------------------------------------------------------------
DATABASE_URL=

# ---------------------------------------------------------------------
# Resend — correos transaccionales. Crea cuenta en resend.com y genera
# API key. Si la dejas vacía, los pedidos se procesan sin enviar correo.
# RESEND_FROM debe ser un dominio verificado en Resend, o usar
# onboarding@resend.dev para pruebas (solo a tu propio correo).
# ---------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM=Outlet Momatt <pedidos@momatt.shop>

# ---------------------------------------------------------------------
# Cron de recordatorios de pago. Cron-job.org (gratis) hace POST a
# /cron/recordatorios?token=CRON_TOKEN cada 6 horas. Genera una cadena
# larga y aleatoria — si se filtra, cambia su valor en Render.
# ---------------------------------------------------------------------
CRON_TOKEN=

# ---------------------------------------------------------------------
# Correos con acceso al panel /admin. Separados por coma, sin espacios.
# Ej.: ADMIN_EMAILS=diego@momatt.shop,ventas@momatt.shop
# ---------------------------------------------------------------------
ADMIN_EMAILS=

# =====================================================================
# CONSTRUCTOR (constructor.py) — herramienta para crear tiendas con IA
# =====================================================================

# ---------------------------------------------------------------------
# Gemini (Google AI). Da vida al asistente: redacta la marca, describe
# productos, genera logos y responde el chatbot. Consíguela gratis en
# https://aistudio.google.com/apikey
# Si la dejas VACÍA, el constructor sigue funcionando en "modo plantilla"
# (textos y logo generados localmente, sin IA).
# ---------------------------------------------------------------------
GEMINI_API_KEY=
# Modelos (opcional, ya traen buenos valores por defecto):
GEMINI_MODELO_TEXTO=gemini-2.5-flash
GEMINI_MODELO_IMAGEN=gemini-2.5-flash-image

# ---------------------------------------------------------------------
# Dominio raíz del constructor. En producción, ponlo a tu dominio real
# (ej. katia.work) y configura un DNS wildcard *.katia.work ->
# tu servidor, para que cada tienda viva en <slug>.katia.work.
# En local déjalo en "localhost": cada tienda se prueba en /t/<slug>.
# ---------------------------------------------------------------------
DOMINIO_BASE=localhost

# URL base para los enlaces en correos cuando NO usas subdominio (dev local).
KATIA_BASE_URL=http://localhost:8001

# ---------------------------------------------------------------------
# Suscripciones de katia (cobro de los PLANES a los dueños de negocio).
# Reusa STRIPE_SECRET_KEY de arriba. Crea 3 precios recurrentes en Stripe
# (Tienda $249, Ventas Pro $799, Escala $1,999 /mes) y pega aquí sus price_id.
# Sin estas llaves, el cambio de plan funciona en "modo demo" (sin cobro).
# Webhook (en Stripe Dashboard): {tu-dominio}/webhook/stripe-suscripcion
#   eventos: checkout.session.completed, customer.subscription.*
# ---------------------------------------------------------------------
STRIPE_PRICE_TIENDA=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ESCALA=
STRIPE_SUB_WEBHOOK_SECRET=

# ---------------------------------------------------------------------
# Recordatorios automáticos del CRM (plan Ventas Pro / Escala).
# Un cron (cron-job.org, gratis) hace GET a:
#   {tu-dominio}/cron/recordatorios?token=CRON_TOKEN   (1 vez al día, en la mañana)
# y katia manda al dueño un correo (vía RESEND_API_KEY, ya configurada arriba)
# con los leads cuyo "próximo contacto" venció. Reusa el mismo CRON_TOKEN.
# Remitente opcional de katia (si no, usa RESEND_FROM):
# ---------------------------------------------------------------------
KATIA_RESEND_FROM=katia <recordatorios@katia.work>
